# Copy this file to .env and fill in values.
# -----------------------------------------------------------------------------
# OFFLINE MODE (default) — runs the whole pipeline with no keys, no network.
# Use this to build the agent + UI while your API keys are still being set up.
USE_MOCK=true
LLM_PROVIDER=mock

# -----------------------------------------------------------------------------
# GO LIVE — once your keys work, comment the two lines above and use these:
#
# USE_MOCK=false
# LLM_PROVIDER=gemini            # or: groq
#
# GEMINI_API_KEY=your_key_here   # https://aistudio.google.com/app/apikey
# GEMINI_MODEL=gemini-2.0-flash
#
# # Fallback if Gemini is geo-blocked:
# GROQ_API_KEY=your_key_here     # https://console.groq.com
# GROQ_MODEL=llama-3.3-70b-versatile
#
# BRIGHTDATA_API_TOKEN=your_token_here   # https://brightdata.com/cp
# BRIGHTDATA_MCP_URL=https://mcp.brightdata.com/mcp

# -----------------------------------------------------------------------------
# Investigation tuning (optional)
MAX_PAGES_TO_SCRAPE=3
MAX_EVIDENCE_CHARS=3500
MCP_TIMEOUT_SECONDS=180
